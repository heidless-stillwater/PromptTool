rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core authentication check
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if the current user is the owner of the resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Global admin bypass check
    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'su'];
    }

    // Users collection
    match /users/{userId} {
      // Profiles are public to authenticated users, but listing is Restricted to Admins
      allow get: if isAuthenticated();
      allow list: if isAdmin();
      
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      
      // Follow lists are public for reading
      match /followers/{followerId} {
        allow read, list: if isAuthenticated();
        // Managed via API
        allow write: if false;
      }
      match /following/{followingId} {
        allow read, list: if isAuthenticated();
        // Managed via API
        allow write: if false;
      }

      // Notifications are private to the recipient
      match /notifications/{notifId} {
        allow read, list, update: if isOwner(userId);
        allow create, delete: if isAdmin(); // System managed
      }

      // Private image portfolio - Only the owner or admin can see all images
      match /images/{imageId} {
        allow read, list: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }

      // Subscriptions and sensitive billing data
      match /subscriptions/{subId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isAdmin(); // Managed via Stripe webhook/API
      }

      // Catch-all for other personal data - Default to Private
      match /{allSubcollections=**} {
        allow read, list, write: if isOwner(userId) || isAdmin();
      }
    }

    // Community Hub - public reading for authenticated users
    match /leagueEntries/{entryId} {
      // Public gallery access
      allow read, list: if isAuthenticated();
      
      // Ownership-based mutations
      allow create: if isAuthenticated() && request.resource.data.originalUserId == request.auth.uid;
      allow update: if isAuthenticated() && (
        (resource.data.originalUserId == request.auth.uid && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['reportCount', 'isModerated'])) || 
        isAdmin()
      );
      allow delete: if isAuthenticated() && (resource.data.originalUserId == request.auth.uid || isAdmin());
      
      // Hub reports (Private to admins)
      match /reports/{reportId} {
        allow read, write: if isAdmin();
      }

      // Community comments
      match /comments/{commentId} {
        allow read, list: if isAuthenticated();
        allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
        allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
        allow update: if false; // Comments generally immutable or handled via API
      }
    }

    // Public/Shared configuration
    match /system/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /promptTemplates/{id} { 
      allow read: if isAuthenticated(); 
      allow write: if isAdmin();
    }
    match /fonts/{id} { 
      allow read: if isAuthenticated(); 
      allow write: if isAdmin();
    }
    match /subscriptionPlans/{id} { 
      allow read: if true; 
      allow write: if isAdmin();
    }
    match /settings/{id} { 
      allow read: if isAuthenticated(); 
      allow write: if isAdmin();
    }
    
    match /analytics/{id} {
      allow read, write: if isAdmin();
    }

    // Timestamped votes for weekly leaderboard and analytics
    match /votes/{voteId} {
      allow get, list: if true; // Public Hall of Fame
      allow write: if false; // Managed via API
    }
  }
}
