rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core authentication check
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if the current user is the owner of the resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users collection
    match /users/{userId} {
      allow get, list: if true; // Public Hall of Fame/Portfolios
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      
      // Follow lists are public for reading
      match /followers/{followerId} {
        allow read, list: if isAuthenticated();
        allow write: if false; // Only via API
      }
      match /following/{followingId} {
        allow read, list: if isAuthenticated();
        allow write: if false; // Only via API
      }

      // Notifications are private to the recipient
      match /notifications/{notifId} {
        allow read, list, update: if isOwner(userId);
        allow create, delete: if isAdmin(); // System managed
      }

      // legacy catch-all for other personal data
      match /{allSubcollections=**} {
        allow read, list, write: if isOwner(userId) || isAdmin();
      }
    }

    // Community League - public reading for authenticated users
    match /leagueEntries/{entryId} {
      // IMPORTANT: Explicitly allowing list for the gallery query
      allow read, list: if isAuthenticated();
      
      // Ownership-based mutations or admin moderation
      allow create: if isAuthenticated() && request.resource.data.originalUserId == request.auth.uid;
      allow update: if isAuthenticated() && (
        (resource.data.originalUserId == request.auth.uid && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['reportCount', 'isModerated'])) || 
        isAdmin()
      );
      allow delete: if isAuthenticated() && (resource.data.originalUserId == request.auth.uid || isAdmin());
      
      // League reports (Private to admins)
      match /reports/{reportId} {
        allow read, write: if isAdmin();
      }

      // League comments
      match /comments/{commentId} {
        allow read, list: if isAuthenticated();
        // Comment deletion only by author or admin
        allow create: if isAuthenticated();
        allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      }
    }

    // Public/Shared configuration
    match /promptTemplates/{id} { 
      allow read: if isAuthenticated(); 
      allow write: if isAdmin();
    }
    match /fonts/{id} { 
      allow read: if isAuthenticated(); 
      allow write: if isAdmin();
    }
    match /subscriptionPlans/{id} { 
      allow read: if true; 
      allow write: if isAdmin();
    }
    match /settings/{id} { 
      allow read: if isAuthenticated(); 
      allow write: if isAdmin();
    }
    
    match /analytics/{id} {
      allow read, write: if isAdmin();
    }

    // Timestamped votes for weekly leaderboard and analytics
    match /votes/{voteId} {
      allow get, list: if true; // Public Hall of Fame
      allow write: if false; // Managed via API
    }
    
    // Global admin bypass check
    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'su'];
    }
  }
}
