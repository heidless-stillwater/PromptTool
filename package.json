        "clsx": "^2.1.1",
        "firebase": "^10.8.0",
        "firebase-admin": "^12.0.0",
        "framer-motion": "^12.34.0",
        "lucide-react": "^0.564.0",
        "next": "14.2.0",
        "react": "^18.3.0",
        "react-dom": "^18.3.0",
        "recharts": "^3.7.0",
